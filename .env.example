# Copy this to .env and fill in your values. Never commit .env.

SECRET_KEY=your-secret-key-here
DEBUG=True

# Leave empty to use SQLite locally. Railway sets this automatically.
DATABASE_URL=

# Set ALLOWED_HOSTS only if DEBUG=False locally (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# PayPal — use sandbox values while testing
PAYPAL_RECEIVER_EMAIL=your-paypal-sandbox@example.com
PAYPAL_TEST=True
PAYPAL_CLIENT_ID=your-paypal-client-id-here
